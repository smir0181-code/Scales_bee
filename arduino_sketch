#include <ESP8266WiFi.h>
#include <WiFiClientSecure.h>
#include <ESP8266HTTPClient.h>
#include <HX711.h>
#include <EEPROM.h>

ADC_MODE(ADC_VCC);

// ================= WIFI =================
const char* ssid = "Xiaomi_-------";
const char* password = "tomas-----";

// ================= SERVER =================
const char* serverName = "https://scales-api-s-----o/api/weight";

// ================= HX711 =================
const int LOADCELL_DOUT_PIN = 5; // D1
const int LOADCELL_SCK_PIN  = 4; // D2

HX711 scale;

float calibration_factor = 19;

// ================= BUTTON =================
const int BUTTON_PIN = 14; // D5
const unsigned long TARE_WAIT_MS = 5000;

// ================= EEPROM =================
const int EEPROM_SIZE = 512;
const int TARE_OFFSET_ADDR = 0;    // long (4 байта)
const int BOOT_COUNT_ADDR   = 4;    // uint32_t (4 байта)

// ================= SLEEP =================
// ull минут в 1 цикле
const uint64_t SLEEP_CYCLE_US = 1ULL * 60ULL * 1000000ULL;

// 3 цикла = 18 минут между отправками
const uint32_t NEEDED_CYCLES = 6;

// ================= GLOBAL =================
float weight = 0;
int battery_percent = 0;

WiFiClientSecure client;

// =====================================================
// EEPROM – работа со счётчиком и тарой
// =====================================================

long readTareOffset() {
  long offset = 0;
  EEPROM.get(TARE_OFFSET_ADDR, offset);
  if (offset == 0xFFFFFFFF || offset == 0) return 0;
  return offset;
}

void saveTareOffset(long offset) {
  EEPROM.put(TARE_OFFSET_ADDR, offset);
  EEPROM.commit();
}

uint32_t readBootCount() {
  uint32_t cnt = 0;
  EEPROM.get(BOOT_COUNT_ADDR, cnt);
  if (cnt == 0xFFFFFFFF || cnt > NEEDED_CYCLES) return 0;
  return cnt;
}

void saveBootCount(uint32_t cnt) {
  EEPROM.put(BOOT_COUNT_ADDR, cnt);
  EEPROM.commit();
}

// =====================================================
// BUTTON
// =====================================================

bool waitForTareButton() {
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  Serial.println("Нажмите кнопку для сброса тары (5 секунд)");
  unsigned long start = millis();
  while (millis() - start < TARE_WAIT_MS) {
    if (digitalRead(BUTTON_PIN) == LOW) {
      delay(50);
      if (digitalRead(BUTTON_PIN) == LOW) {
        Serial.println("Сброс тары");
        while (digitalRead(BUTTON_PIN) == LOW) delay(10);
        return true;
      }
    }
    delay(100);
  }
  return false;
}

// =====================================================
// WEIGHT
// =====================================================

void readWeightWithTare() {
  Serial.println("Запуск HX711");
  scale.begin(LOADCELL_DOUT_PIN, LOADCELL_SCK_PIN);  
  scale.set_scale(calibration_factor);
  delay(300);

  long savedOffset = readTareOffset();
  if (savedOffset != 0) {
    scale.set_offset(savedOffset);
    Serial.print("Тара: "); Serial.println(savedOffset);
  } else {
    Serial.println("Тара не найдена");
  }

  if (waitForTareButton()) {
    scale.tare();
    long newOffset = scale.get_offset();
    saveTareOffset(newOffset);
    Serial.print("Новая тара: "); Serial.println(newOffset);
  }

  if (scale.is_ready()) {
    weight = scale.get_units(10);
    Serial.print("Вес: "); Serial.print(weight); Serial.println(" g");
  } else {
    Serial.println("HX711 ERROR");
    weight = 0;
  }
}


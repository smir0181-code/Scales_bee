#include <ESP8266WiFi.h>
#include <WiFiClientSecure.h>
#include <ESP8266HTTPClient.h>
#include <HX711.h>
#include <EEPROM.h>

ADC_MODE(ADC_VCC);

// ================= WIFI =================
const char* ssid = "Xi----_03F7";
const char* password = "to-------r10";

// ================= SERVER =================
const char* serverName = "https://scales-api-s------";

// ================= HX711 =================
const int LOADCELL_DOUT_PIN = 5; // D1
const int LOADCELL_SCK_PIN  = 4; // D2

HX711 scale;

float calibration_factor = 19;

// ================= BUTTON =================
const int BUTTON_PIN = 14; // D5
const unsigned long TARE_WAIT_MS = 5000;

// ================= EEPROM =================
const int EEPROM_SIZE = 512;
const int TARE_OFFSET_ADDR = 0;

// ================= SLEEP =================

// 6 минут
const uint64_t SLEEP_CYCLE_US = 60ULL * 60ULL * 1000000ULL;

// 6 циклов = 36 минут
const uint32_t NEEDED_CYCLES = 3;

// ================= RTC =================
uint32_t bootCount = 0;

// ================= GLOBAL =================
float weight = 0;
int battery_percent = 0;

WiFiClientSecure client;

// =====================================================
// EEPROM
// =====================================================

long readTareOffset() {

  long offset = 0;

  EEPROM.get(TARE_OFFSET_ADDR, offset);

  if (offset == 0xFFFFFFFF || offset == 0) {
    return 0;
  }

  return offset;
}

void saveTareOffset(long offset) {

  EEPROM.put(TARE_OFFSET_ADDR, offset);

  EEPROM.commit();
}

// =====================================================
// BUTTON
// =====================================================

bool waitForTareButton() {

  pinMode(BUTTON_PIN, INPUT_PULLUP);

  Serial.println("Нажмите кнопку для сброса тары");

  unsigned long start = millis();

  while (millis() - start < TARE_WAIT_MS) {

    if (digitalRead(BUTTON_PIN) == LOW) {

      delay(50);

      if (digitalRead(BUTTON_PIN) == LOW) {

        Serial.println("Сброс тары");

        while (digitalRead(BUTTON_PIN) == LOW) {
          delay(10);
        }

        return true;
      }
    }

    delay(100);
  }

  return false;
}

// =====================================================
// WEIGHT
// =====================================================

void readWeightWithTare() {

  Serial.println("Запуск HX711");

  scale.begin(LOADCELL_DOUT_PIN, LOADCELL_SCK_PIN);

  delay(300);

  scale.set_scale(calibration_factor);

  long savedOffset = readTareOffset();

  if (savedOffset != 0) {

    scale.set_offset(savedOffset);

    Serial.print("Тара: ");
    Serial.println(savedOffset);

  } else {

    Serial.println("Тара не найдена");
  }

  if (waitForTareButton()) {

    scale.tare();

    long newOffset = scale.get_offset();

    saveTareOffset(newOffset);

    Serial.print("Новая тара: ");
    Serial.println(newOffset);
  }

  if (scale.is_ready()) {

    weight = scale.get_units(10);

    Serial.print("Вес: ");
    Serial.print(weight);
    Serial.println(" g");

  } else {

    Serial.println("HX711 ERROR");

    weight = 0;
  }
}

// =====================================================
// BATTERY
// =====================================================

void readBattery() {

  int battery_mv = ESP.getVcc() * 1.3;

  battery_percent = map(battery_mv, 3000, 4200, 0, 100);

  battery_percent = constrain(battery_percent, 0, 100);

  Serial.print("Battery: ");
  Serial.print(battery_mv);

  Serial.print(" mV ");

  Serial.print(battery_percent);

  Serial.println("%");
}

// =====================================================
// WIFI
// =====================================================

void connectWiFi() {

  Serial.println("WiFi START");

  WiFi.persistent(false);

  WiFi.mode(WIFI_STA);

  delay(100);

  WiFi.begin(ssid, password);

  Serial.print("Connecting");

  int timeout = 0;

  while (WiFi.status() != WL_CONNECTED && timeout < 40) {

    delay(500);

    Serial.print(".");

    timeout++;
  }

  if (WiFi.status() == WL_CONNECTED) {

    Serial.println();

    Serial.println("WiFi OK");

    Serial.print("IP: ");

    Serial.println(WiFi.localIP());

  } else {

    Serial.println();

    Serial.println("WiFi FAILED");
  }
}

// =====================================================
// SEND
// =====================================================

void sendData() {

  if (WiFi.status() != WL_CONNECTED) {

    Serial.println("WiFi нет");

    return;
  }

  client.setInsecure();

  HTTPClient http;

  String jsonPayload =
    "{\"weight\":" + String(weight, 2) +
    ",\"battery\":" + String(battery_percent) + "}";

  Serial.println("JSON:");

  Serial.println(jsonPayload);

  http.begin(client, serverName);

  http.addHeader("Content-Type", "application/json");

  int httpCode = http.POST(jsonPayload);

  if (httpCode > 0) {

    Serial.print("HTTP: ");

    Serial.println(httpCode);

    Serial.println(http.getString());

  } else {

    Serial.print("HTTP ERROR: ");

    Serial.println(httpCode);
  }

  http.end();
}

// =====================================================
// SLEEP
// =====================================================

void goToSleepCycle() {

  bootCount++;

  Serial.println();
  Serial.print("Цикл: ");
  Serial.print(bootCount);
  Serial.print(" / ");
  Serial.println(NEEDED_CYCLES);

  ESP.rtcUserMemoryWrite(0, &bootCount, sizeof(bootCount));

  if (bootCount >= NEEDED_CYCLES) {

    Serial.println();
    Serial.println("Выполняем измерение и отправку");

    bootCount = 0;

    ESP.rtcUserMemoryWrite(0, &bootCount, sizeof(bootCount));

    delay(1000);

    readBattery();

    readWeightWithTare();

    connectWiFi();

    sendData();
  }

  Serial.println();
  Serial.println("Подготовка ко сну");

  client.stop();

  scale.power_down();

  WiFi.mode(WIFI_OFF);

  delay(100);

  Serial.println("Deep Sleep");

  Serial.flush();

  ESP.deepSleep(SLEEP_CYCLE_US, WAKE_RF_DEFAULT);
}

// =====================================================
// SETUP
// =====================================================

void setup() {

  Serial.begin(115200);

  delay(1000);

  Serial.println();
  Serial.println("====================");
  Serial.println("Весы улья");
  Serial.println("====================");

  EEPROM.begin(EEPROM_SIZE);

  ESP.rtcUserMemoryRead(0, &bootCount, sizeof(bootCount));

  if (bootCount == 0xFFFFFFFF || bootCount > NEEDED_CYCLES) {

    bootCount = 0;
  }

  Serial.print("RTC bootCount: ");

  Serial.println(bootCount);

  if (bootCount == 0) {

    Serial.println();
    Serial.println("Первый запуск");

    readBattery();

    readWeightWithTare();

    connectWiFi();

    sendData();
  }

  goToSleepCycle();
}

// =====================================================
// LOOP
// =====================================================

void loop() {

}

#include <ESP8266WiFi.h>
#include <WiFiClientSecure.h>
#include <ESP8266HTTPClient.h>
#include <HX711.h>

const char* ssid = "Xiaomi_03F7";
const char* password = "tomasguitar10";
const char* serverName = "https://scales-api-smiranton.amvera.io/api/weight";   // ← правильный адрес

const int LOADCELL_DOUT_PIN = 5;
const int LOADCELL_SCK_PIN  = 4;

HX711 scale;
float calibration_factor = 18.5;
float weight = 0;

WiFiClientSecure client;

void setup() {
  Serial.begin(115200);
  Serial.println("\n=== Весы для улья ===\n");

  WiFi.begin(ssid, password);
  Serial.print("Подключение к Wi-Fi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWi-Fi подключен. IP: " + WiFi.localIP().toString());

  client.setInsecure();   // отключаем проверку сертификата

  Serial.println("Инициализация HX711...");
  scale.begin(LOADCELL_DOUT_PIN, LOADCELL_SCK_PIN);
  Serial.print("Ожидание HX711");
  while (!scale.is_ready()) {
    delay(100);
    Serial.print(".");
  }
  Serial.println(" OK");

  scale.set_scale(calibration_factor);
  scale.tare();
  Serial.println("Тарировка выполнена. Вес обнулён.\n");
}

void loop() {
  if (scale.is_ready()) {
    weight = scale.get_units(10);
    Serial.print("Измеренный вес: ");
    Serial.print(weight);
    Serial.println(" g");
  } else {
    Serial.println("Ошибка: HX711 не отвечает!");
    delay(2000);
    return;
  }

  if (WiFi.status() == WL_CONNECTED) {
    HTTPClient http;
    String jsonPayload = "{\"weight\":" + String(weight) + "}";
    http.begin(client, serverName);
    http.addHeader("Content-Type", "application/json");
    int httpCode = http.POST(jsonPayload);
    if (httpCode > 0) {
      Serial.print("Код ответа сервера: ");
      Serial.println(httpCode);
      String response = http.getString();
      Serial.println("Ответ: " + response);
    } else {
      Serial.print("Ошибка отправки: ");
      Serial.println(httpCode);
    }
    http.end();
  } else {
    Serial.println("Wi-Fi потерян. Попытка переподключения...");
    WiFi.reconnect();
  }
  delay(10000);   // пауза 10 секунд
}